{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Proxer",
  "version": "0.1.1",
  "identifier": "com.skuntir.proxer",
  "build": {
    "beforeDevCommand": "npm --prefix frontend run dev || npm --prefix ../frontend run dev",
    "beforeBuildCommand": "npm --prefix frontend run build || npm --prefix ../frontend run build",
    "devUrl": "http://localhost:3000",
    "frontendDist": "../frontend/out"
  },
  "app": {
    "windows": [
      {
        "title": "Proxer",
        "width": 1280,
        "height": 800,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.ico", "icons/Logo.png"]
  }
}
